---
import { getCollection } from 'astro:content';

const slides = (await getCollection('slides')).sort((a, b) => a.data.order - b.data.order);
---

{
  slides.length > 0 && (
    <section
      id="hero-slider"
      class="relative isolate overflow-hidden bg-primary"
      aria-roledescription="carousel"
      aria-label="Aktuelles vom TV Geislar"
    >
      <div class="relative h-[60vh] min-h-[360px] max-h-[640px]">
        {slides.map((slide, i) => (
          <div
            class:list={[
              'hero-slide absolute inset-0 transition-opacity duration-700 ease-in-out',
              i === 0 ? 'opacity-100' : 'pointer-events-none opacity-0',
            ]}
            data-index={i}
            aria-hidden={i === 0 ? 'false' : 'true'}
          >
            {slide.data.image ? (
              <img
                src={slide.data.image}
                alt={slide.data.alt ?? slide.data.headline}
                class="absolute inset-0 h-full w-full object-cover"
              />
            ) : (
              <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-600 to-secondary-500" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/20 to-transparent" />
            <div class="relative mx-auto flex h-full max-w-6xl flex-col items-start justify-end px-6 pb-16 text-white">
              <h2 class="max-w-2xl text-3xl font-bold leading-tight drop-shadow sm:text-4xl md:text-5xl">
                {slide.data.headline}
              </h2>
              {slide.data.text && (
                <p class="mt-3 max-w-xl text-base text-white/90 drop-shadow sm:text-lg">
                  {slide.data.text}
                </p>
              )}
              {slide.data.ctaLabel && slide.data.ctaHref && (
                <a class="btn-secondary mt-6" href={slide.data.ctaHref}>
                  {slide.data.ctaLabel}
                </a>
              )}
            </div>
          </div>
        ))}

        {slides.length > 1 && (
          <>
            <button
              type="button"
              id="hero-prev"
              class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/30 p-2 text-white backdrop-blur transition hover:bg-white/50"
              aria-label="Vorheriger Slide"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <button
              type="button"
              id="hero-next"
              class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/30 p-2 text-white backdrop-blur transition hover:bg-white/50"
              aria-label="Nächster Slide"
            >
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>

            <div id="hero-dots" class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-2">
              {slides.map((_, i) => (
                <button
                  type="button"
                  class:list={[
                    'hero-dot h-2.5 w-2.5 rounded-full transition',
                    i === 0 ? 'bg-white' : 'bg-white/50 hover:bg-white/80',
                  ]}
                  data-index={i}
                  aria-label={`Zu Slide ${i + 1}`}
                />
              ))}
            </div>
          </>
        )}
      </div>

      <script is:inline>
        (function () {
          const root = document.getElementById('hero-slider');
          if (!root) return;
          const slides = Array.from(root.querySelectorAll('.hero-slide'));
          const dots = Array.from(root.querySelectorAll('.hero-dot'));
          if (slides.length < 2) return;
          let current = 0;
          let timer;

          function show(n) {
            current = (n + slides.length) % slides.length;
            slides.forEach((s, i) => {
              const active = i === current;
              s.classList.toggle('opacity-100', active);
              s.classList.toggle('opacity-0', !active);
              s.classList.toggle('pointer-events-none', !active);
              s.setAttribute('aria-hidden', String(!active));
            });
            dots.forEach((d, i) => {
              d.classList.toggle('bg-white', i === current);
              d.classList.toggle('bg-white/50', i !== current);
            });
          }
          function next() { show(current + 1); }
          function prev() { show(current - 1); }
          function start() { timer = window.setInterval(next, 6000); }
          function reset() { window.clearInterval(timer); start(); }

          root.querySelector('#hero-next')?.addEventListener('click', () => { next(); reset(); });
          root.querySelector('#hero-prev')?.addEventListener('click', () => { prev(); reset(); });
          dots.forEach((d) =>
            d.addEventListener('click', () => { show(Number(d.dataset.index)); reset(); })
          );
          root.addEventListener('mouseenter', () => window.clearInterval(timer));
          root.addEventListener('mouseleave', start);
          start();
        })();
      </script>
    </section>
  )
}
