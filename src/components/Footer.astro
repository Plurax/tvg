---
import { getCollection } from 'astro:content';

const abteilungen = (await getCollection('abteilungen')).sort(
  (a, b) => a.data.order - b.data.order
);

const year = new Date().getFullYear();
---

<footer class="mt-20 bg-primary text-primary-50">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <img
        src="/TVG_Logo_blau_M_2026_01.png"
        alt="TV Geislar 1925 e.V."
        class="h-14 w-auto rounded bg-white p-1"
      />
      <p class="mt-4 text-sm text-primary-100">
        Turnverein Geislar 1925 e.V. — Sport und Gemeinschaft in Bonn-Geislar seit 1925.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-white">Abteilungen</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {abteilungen.map((a) => (
          <li>
            <a class="text-primary-100 hover:text-secondary-300" href={`/abteilungen/${a.id}`}>
              {a.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-white">Verein</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-primary-100 hover:text-secondary-300" href="/verein">Über uns</a></li>
        <li><a class="text-primary-100 hover:text-secondary-300" href="/neuigkeiten">Neuigkeiten</a></li>
        <li><a class="text-primary-100 hover:text-secondary-300" href="/mitgliedschaft">Mitgliedschaft</a></li>
        <li><a class="text-primary-100 hover:text-secondary-300" href="/kontakt">Kontakt</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-white">Kontakt</h3>
      <address class="mt-3 space-y-2 text-sm not-italic text-primary-100">
        <p>TV Geislar 1925 e.V.<br />53225 Bonn-Geislar</p>
        <p>
          <a class="hover:text-secondary-300" href="mailto:vorstand@tv-geislar.de">vorstand@tv-geislar.de</a>
        </p>
      </address>
    </div>
  </div>

  <div class="border-t border-primary-700">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 py-4 text-xs text-primary-200 sm:flex-row">
      <p>© {year} TV Geislar 1925 e.V.</p>
      <nav class="flex gap-4">
        <a class="hover:text-secondary-300" href="/impressum">Impressum</a>
        <a class="hover:text-secondary-300" href="/datenschutz">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>
