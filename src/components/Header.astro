---
import { getCollection } from 'astro:content';

const abteilungen = (await getCollection('abteilungen')).sort(
  (a, b) => a.data.order - b.data.order
);

const navItems = [
  { label: 'Start', href: '/' },
  { label: 'Verein', href: '/verein' },
  { label: 'Neuigkeiten', href: '/neuigkeiten' },
  { label: 'Mitgliedschaft', href: '/mitgliedschaft' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-3">
      <img
        src="/TVG_Logo_blau_M_2026_01.png"
        alt="TV Geislar 1925 e.V."
        class="h-12 w-auto"
      />
      <span class="sr-only">TV Geislar 1925 e.V.</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 text-sm font-medium text-primary-900 lg:flex">
      <a class="rounded px-3 py-2 hover:bg-primary-50 hover:text-primary" href="/">Start</a>
      <a class="rounded px-3 py-2 hover:bg-primary-50 hover:text-primary" href="/verein">Verein</a>

      <div class="group relative">
        <button
          type="button"
          class="flex items-center gap-1 rounded px-3 py-2 hover:bg-primary-50 hover:text-primary"
          aria-haspopup="true"
        >
          Abteilungen
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="invisible absolute left-0 top-full w-56 translate-y-1 rounded-lg border border-slate-200 bg-white p-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
          <a class="block rounded px-3 py-2 text-sm hover:bg-primary-50 hover:text-primary" href="/abteilungen">Übersicht</a>
          {abteilungen.map((a) => (
            <a class="block rounded px-3 py-2 text-sm hover:bg-primary-50 hover:text-primary" href={`/abteilungen/${a.id}`}>
              {a.data.title}
            </a>
          ))}
        </div>
      </div>

      <a class="rounded px-3 py-2 hover:bg-primary-50 hover:text-primary" href="/neuigkeiten">Neuigkeiten</a>
      <a class="rounded px-3 py-2 hover:bg-primary-50 hover:text-primary" href="/mitgliedschaft">Mitgliedschaft</a>
      <a class="ml-1 btn-primary !px-4 !py-2" href="/kontakt">Kontakt</a>
    </nav>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-primary hover:bg-primary-50 lg:hidden"
      aria-label="Menü öffnen"
      aria-expanded="false"
    >
      <svg id="icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-nav" class="hidden border-t border-slate-200 bg-white px-4 py-3 lg:hidden">
    <div class="grid gap-1 text-sm font-medium text-primary-900">
      {navItems.map((item) => (
        <a class="rounded px-3 py-2 hover:bg-primary-50" href={item.href}>{item.label}</a>
      ))}
      <div class="mt-1 border-t border-slate-100 pt-2">
        <p class="px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-400">Abteilungen</p>
        <a class="rounded px-3 py-2 hover:bg-primary-50 block" href="/abteilungen">Übersicht</a>
        {abteilungen.map((a) => (
          <a class="rounded px-3 py-2 hover:bg-primary-50 block" href={`/abteilungen/${a.id}`}>{a.data.title}</a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('menu-toggle');
    const nav = document.getElementById('mobile-nav');
    const open = document.getElementById('icon-open');
    const close = document.getElementById('icon-close');
    if (!btn || !nav) return;
    btn.addEventListener('click', function () {
      const hidden = nav.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!hidden));
      open?.classList.toggle('hidden', !hidden);
      close?.classList.toggle('hidden', hidden);
    });
  })();
</script>
