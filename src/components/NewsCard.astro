---
interface Props {
  title: string;
  date: Date;
  category?: string;
  href: string;
}

const { title, date, category, href } = Astro.props;

const fmtDate = date.toLocaleDateString('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={href}
  class="group flex h-full flex-col rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
>
  <div class="flex items-center gap-3 text-xs text-slate-500">
    <time>{fmtDate}</time>
    {category && (
      <span class="rounded bg-secondary-50 px-2 py-0.5 font-medium text-secondary-700">
        {category}
      </span>
    )}
  </div>
  <h3 class="mt-2 text-lg font-semibold text-primary group-hover:text-secondary-600">
    {title}
  </h3>
  <span class="mt-auto pt-4 text-sm font-medium text-secondary-600 group-hover:text-secondary-700">
    Weiterlesen →
  </span>
</a>
