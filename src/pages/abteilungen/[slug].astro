---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';

export async function getStaticPaths() {
  const abteilungen = await getCollection('abteilungen');
  return abteilungen.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, summary, accent, trainingszeiten, ansprechpartner, branch, newsCategory } = entry.data;

const related = (await getCollection('blog'))
  .filter(
    (p) =>
      (branch && p.data.branch === branch) ||
      (newsCategory && p.data.category === newsCategory)
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title={`${title} – TV Geislar 1925 e.V.`} fullWidth>
  <!-- Banner -->
  <section
    class="bg-primary"
    style={accent ? `background-color:${accent}` : undefined}
  >
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-sm font-semibold uppercase tracking-wide text-white/70">Abteilung</p>
      <h1 class="mt-1 text-4xl font-bold text-white">{title}</h1>
      <p class="mt-3 max-w-2xl text-white/90">{summary}</p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <article class="prose prose-slate max-w-none prose-headings:text-primary prose-a:text-secondary-600">
          <Content />
        </article>

        {trainingszeiten && trainingszeiten.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl font-bold text-primary">Trainingszeiten</h2>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full border-collapse text-left text-sm">
                <thead>
                  <tr class="border-b border-slate-200 text-slate-500">
                    <th class="py-2 pr-4 font-semibold">Gruppe</th>
                    <th class="py-2 pr-4 font-semibold">Tag</th>
                    <th class="py-2 pr-4 font-semibold">Zeit</th>
                    <th class="py-2 font-semibold">Ort</th>
                  </tr>
                </thead>
                <tbody>
                  {trainingszeiten.map((t) => (
                    <tr class="border-b border-slate-100">
                      <td class="py-2 pr-4 font-medium text-slate-800">{t.gruppe}</td>
                      <td class="py-2 pr-4 text-slate-600">{t.tag}</td>
                      <td class="py-2 pr-4 text-slate-600">{t.zeit}</td>
                      <td class="py-2 text-slate-600">{t.ort ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-8">
        {ansprechpartner && ansprechpartner.length > 0 && (
          <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-bold text-primary">Ansprechpartner</h2>
            <ul class="mt-4 space-y-4">
              {ansprechpartner.map((p) => (
                <li>
                  <p class="font-semibold text-slate-800">{p.name}</p>
                  {p.rolle && <p class="text-sm text-slate-500">{p.rolle}</p>}
                  {p.email && (
                    <a class="text-sm text-secondary-600 hover:text-secondary-700" href={`mailto:${p.email}`}>
                      {p.email}
                    </a>
                  )}
                  {p.telefon && <p class="text-sm text-slate-600">{p.telefon}</p>}
                </li>
              ))}
            </ul>
          </section>
        )}

        <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-bold text-primary">Mitmachen</h2>
          <p class="mt-2 text-sm text-slate-600">
            Interesse an dieser Abteilung? Komm zum Schnuppertraining oder werde Mitglied.
          </p>
          <a class="btn-primary mt-4 w-full" href="/mitgliedschaft">Mitglied werden</a>
        </section>
      </aside>
    </div>

    {related.length > 0 && (
      <section class="mt-14">
        <h2 class="text-xl font-bold text-primary">Aktuelles aus der Abteilung</h2>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {related.map((p) => (
            <NewsCard
              title={p.data.title}
              date={p.data.date}
              category={p.data.category}
              href={`/neuigkeiten/${p.id}`}
            />
          ))}
        </div>
      </section>
    )}

    <p class="mt-12">
      <a class="text-sm font-semibold text-secondary-600 hover:text-secondary-700" href="/abteilungen">
        ← Alle Abteilungen
      </a>
    </p>
  </div>
</BaseLayout>
